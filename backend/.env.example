# Application Configuration
# ==========================================
PORT=3000
NODE_ENV=development
ADVERTISED_HOST=http://localhost:3000

# Health Check Configuration
# ==========================================
HEALTH_CHECK_MAX_MEMORY_UTILIZATION=8
HEALTH_CHECK_MAX_DISK_USAGE_PERCENT=0.99

# Database Configuration
# ==========================================
DATABASE_URL="postgresql://user:password@localhost:5432/db?schema=public"

# Redis Configuration (for cache and BullMQ)
# ==========================================
REDIS_URL=""
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""
REDIS_DB=0

# JWT Configuration
# ==========================================
JWT_SECRET=secret-key-change-in-production
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=refresh-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# OAuth Configuration
# ==========================================
# Google OAuth - https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# GitHub OAuth - https://github.com/settings/developers
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# S3 Storage Configuration
# ==========================================
S3_PORT=443
S3_USE_SSL=true
S3_ENDPOINT="s3-endpoint"
S3_REGION="us-east-1"
S3_ACCESS_KEY="s3-access-key"
S3_SECRET_KEY="s3-secret-key"
S3_DEFAULT_BUCKET="default-s3-bucket-name"
S3_BUCKETS='{"biz":"biz-s3-bucket-name"}'
S3_PUBLIC_URL_PREFIX=""

# Email Configuration (for nodemailer)
# ==========================================
SMTP_HOST="smtp.example.com"
SMTP_PORT=465
SMTP_USER="user@example.com"
SMTP_PASSWORD="password"

# LLM Configuration
# ==========================================
LLM_API_KEY=api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4-turbo-preview
LLM_TEMPERATURE=0.7
LLM_TIMEOUT_SEC=600

# LangGraph Configuration
# ==========================================
LANGGRAPH_RECURSION_LIMIT=25
LANGGRAPH_MAX_RETRIES=3
LANGGRAPH_RETRY_DELAY=1000
LANGGRAPH_BACKOFF_MULTIPLIER=2
LANGGRAPH_MAX_DELAY=10000

# Weaviate Configuration
# ==========================================
EMBEDDING_MODEL_NAME="text-embedding-3-small"
EMBEDDING_MODEL_API_KEY="sk-1234567890abcdef1234567890abcdef"
EMBEDDING_MODEL_BASE_URL=""
EMBEDDING_MODEL_DIMENSIONS=768
EMBEDDING_WEAVIATE_SCHEME="http"
EMBEDDING_WEAVIATE_HOST="localhost"
EMBEDDING_WEAVIATE_PORT="8080"
EMBEDDING_WEAVIATE_PATH=""
EMBEDDING_WEAVIATE_API_KEY="weaviate-api-key"


# OpenTelementry Configuration
# ==========================================
SERVICE_NAME="backend"
SERVICE_VERSION="1.0.0"
DEPLOY_ENV="prod" # prod, staging, dev

OTEL_ENABLE_METRICS=true
OTEL_ENABLE_LOGS=true

# Exporter options: otlp, prometheus, console, file
OTEL_METRICS_EXPORTER="file"
# Exporter options: otlp, console
OTEL_LOGS_EXPORTER="otlp"

# OTLP Configuration
OTLP_ENDPOINT="http://otel-collector:4318/v1"
OTEL_OTLP_HEADERS=""

# Metrics Configuration
# Interval in seconds
OTEL_METRICS_EXPORT_INTERVAL=30
# Port for Prometheus exporter (if used)
PROMETHEUS_PORT=9464
