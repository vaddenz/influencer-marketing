{
  "defaultMode": "code",
  "permissions": {
    "allow": [
      "Read(*.js, *.ts, *.jsx, *.tsx, *.json, *.md, *.yml, *.html, *.css, *.scss)",
      "Read(src/**, app/**, public/**, components/**, lib/**, utils/**, tests/**)",
      "Write(src/**, app/**, public/**, components/**, lib/**, utils/**, tests/**)",
      "Glob(**/*.tsx, **/*.ts, **/*.jsx, **/*.js)",
      "Grep(app/**, src/**, components/**)",
      "Bash(next dev)",
      "Bash(next lint)",
      "Bash(next info)",
      "Bash(nest start --watch)",
      "Bash(nest info)",
      "Bash(nest --version)",
      "Bash(npm run lint)",
      "Bash(pnpm run lint)",
      "Bash(yarn run lint)",
      "Bash(prettier --check .)",
      "Bash(prettier --write src/**/*.{ts,tsx} app/**/*.{ts,tsx})",
      "Bash(eslint src/** app/**)",
      "Bash(tsc --noEmit)",
      "Bash(ls, ls -la, pwd, cat, head, tail, find)",
      "Bash(git status, git diff, git log --oneline -n 10)",
      "Read(.env, .env.example, .env.local, .env.development)",
      "Write(.env, .env.example, .env.local, .env.development)",
      "Bash(git commit -m *, git checkout -b *)",
      "NodeJS(console.log, fs.readFile, path, process.cwd)",
      "Python(print, json, yaml)",
      "mcp__plugin_playwright__*"
    ],
    "ask": [
      "Bash(npm install *, npm uninstall *)",
      "Bash(pnpm add *, pnpm remove *)",
      "Bash(yarn add *, yarn remove *)",
      "Bash(next build)",
      "Bash(next start)",
      "Bash(next export)",
      "Bash(nest build)",
      "Bash(nest start)",
      "Bash(nest generate module *, nest generate controller *, nest generate service *)",
      "Bash(git checkout *)",
      "Bash(npm run build, pnpm run build, yarn run build)",
      "Bash(rm -rf dist/, rm -rf .next/, rm -rf build/)",
      "Bash(npm run test, pnpm run test, yarn run test)",
      "Write(package.json, tsconfig.json, next.config.js, nest-cli.json)",
      "Write(tailwind.config.js, postcss.config.js)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(rm -rf /*, rm -rf ~/*, rm -rf /home/*)",
      "Bash(chmod 777, chown *)",
      "Bash(curl *, wget *, ssh *, scp *, rsync *)",
      "Bash(npm publish, yarn publish)",
      "Bash(git push, git pull --force, git reset --hard, git rebase *)",
      "Read(.env.production)",
      "Read(secrets/**, *.pem, *.key, credentials.json, id_rsa)",
      "Read(~/.ssh/**, ~/.aws/**, ~/.npmrc, /etc/**)",
      "Write(.env.production, secrets/**, *.pem, *.key)",
      "Write(package-lock.json, pnpm-lock.yaml, yarn.lock)"
    ]
  },
  "env": {},
  "memory": {
    "persist": true,
    "cleanupPeriodDays": 30
  },
  "editor": {
    "defaultEditor": "code",
    "autoOpenFiles": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "yarn p",
            "statusMessage": "Running prettier..."
          }
        ]
      }
    ]
  }
}
